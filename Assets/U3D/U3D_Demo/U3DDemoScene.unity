--- !u!114 &2028324282
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2028324279}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 0
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>BASIC MOVEMENT</b>\r\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\r\nWalk:
    W A S D  or  Arrow Keys\r\nRun: Shift (toggle)\r\nJump: Space\r\nCrouch: C\r\n\r\n<b>CAMERA
    + UI</b>\r\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\r\nLook:
    Right Mouse + Move\r\nInteract: R\r\nFree Cursor (stay in game): Tab\r\nFree
    Cursor (return to browser): Esc\r\nZoom: Mouse Wheel\r\n\r\n<b>SPECIAL MOVEMENT</b>\r\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\r\nFly:
    F (toggle)\r\nStrafe: Q / E\r\nMove Forward: Left + Right Mouse\r\nSteer: Left
    + Right Mouse + Move Mouse\r\nAuto-Run: Num Lock (toggle)\r\nTeleport: Double-Click\r\n\r\n<b>ALL
    INPUT BINDINGS</b>\r\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\r\nMove:
    W / \u2191 / S / \u2193 / A / \u2190 / D / \u2192\r\nJump: Space\r\nSprint: Shift\r\nCrouch:
    C\r\nZoom: Middle Button\r\nTeleport: Left Button\r\nFly: F\r\nCamera Perspective:
    Scroll/Y\r\nInteract: R\r\nFree Cursor (stay in game): Tab\r\nFree Cursor (return
    to browser): Escape\r\nPrimary Click: Left Button\r\nCamera Look (hold): Right
    Button\r\nStrafeLeft: Q\r\nStrafeRight: E\r\nTurnLeft: A\r\nTurnRight: D\r\nAuto-Run:
    Num Lock\r\n\r\n<b>VR CONTROLS</b>\r\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\r\nLook:
    Right {Primary2DAxis}\r\nMove: Left {Primary2DAxis}\r\nJump: Right {Primary Button}\r\nSprint:
    Left Trigger\r\nCrouch: Left {Secondary Button}\r\nZoom: Right {Secondary Button}\r\nTeleport:
    Left {Primary2DAxis Click}\r\nFly: Left {Grip Button}\r\nCamera Perspective:
    Right {Primary2DAxis Click}\r\nInteract: Right {Grip Button}  |  Right Trigger\r\nAuto-Run:
    Left {Primary Button}\r\nLeftHandPosition: Left Controller Position\r\nLeftHandRotation:
    Left Controller Rotation\r\nRightHandPosition: Right Controller Position\r\nRightHandRotation:
    Right Controller Rotation\r\nHeadPosition: Headset Position\r\nHeadRotation:
    Headset Rotation\r\nHeadTrackingState: tracking State\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
